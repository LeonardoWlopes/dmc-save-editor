		"tsx": "^4.21.0",
		"typescript": "~5.7.3",
		"vite": "^6.4.1",
		"vite-plugin-svgr": "^4.5.0",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.2.4",
		"bun-types": "latest"
